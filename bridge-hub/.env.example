# Bridge Hub Configuration
# ========================

# -----------------------------------------------------------------------------
# 基础配置 (Core Settings)
# -----------------------------------------------------------------------------

# WebSocket 服务器端口 (默认: 38471)
PORT=38471

# 认证令牌 (Plugin 连接时使用)
# 可选：如未设置，会自动生成并显示在控制台
AUTH_TOKEN=

# -----------------------------------------------------------------------------
# 适配器配置 (Adapter Settings)
# -----------------------------------------------------------------------------
# 启用哪些适配器，逗号分隔
# 可选值: telegram, discord
# 示例: ADAPTERS=telegram,discord
ADAPTERS=telegram

# -----------------------------------------------------------------------------
# Telegram 适配器配置
# -----------------------------------------------------------------------------
# 必填: 从 @BotFather 获取的 Bot Token
TELEGRAM_BOT_TOKEN=

# 可选: 允许的用户 ID 列表 (逗号分隔，留空允许所有用户)
TELEGRAM_ADMIN_USERS=

# 可选: 允许的群组/频道 ID 列表 (逗号分隔，留空允许所有)
# 群组 ID 通常以 -100 开头
TELEGRAM_ALLOWED_CHATS=

# -----------------------------------------------------------------------------
# Discord 适配器配置
# -----------------------------------------------------------------------------
# 必填: Discord Bot Token
DISCORD_BOT_TOKEN=

# 必填: 默认频道 ID (用于创建线程)
DISCORD_CHANNEL_ID=

# 可选: 允许的用户 ID 列表 (逗号分隔，留空允许所有用户)
DISCORD_ADMIN_USERS=

# -----------------------------------------------------------------------------
# 未来扩展 (预留)
# -----------------------------------------------------------------------------
# Slack 适配器
# SLACK_BOT_TOKEN=
# SLACK_CHANNEL_ID=
# SLACK_ADMIN_USERS=

# 企业微信
# WECHAT_WORK_CORP_ID=
# WECHAT_WORK_AGENT_ID=
# WECHAT_WORK_SECRET=
# WECHAT_WORK_ADMIN_USERS=
