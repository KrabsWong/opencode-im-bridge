# Bridge Hub Configuration

# WebSocket server port (default: 38471 - random high port to avoid conflicts)
PORT=38471

# Authentication token (plugins must use this to connect)
# Optional: if not set, a random token will be auto-generated and printed to console
AUTH_TOKEN=

# Telegram Bot Token (from @BotFather) - REQUIRED
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Comma-separated list of authorized Telegram user IDs (leave empty to allow all)
ADMIN_USERS=

# Comma-separated list of allowed Telegram group/chat IDs (leave empty to allow all)
# Group IDs usually start with -100
ALLOWED_CHATS=
