{
  "name": "my-opencode-project",
  "opencode": {
    "plugin": [
      ["opencode-im-bridge", {
        "platform": "telegram",
        "platformConfig": {
          "botToken": "${TELEGRAM_BOT_TOKEN}",
          "chatId": "${TELEGRAM_CHAT_ID}"
        },
        "bridgeConfig": {
          "adminUsers": ["${TELEGRAM_USER_ID}"],
          "features": {
            "questions": true,
            "permissions": true,
            "statusQuery": true,
            "directMessaging": true
          }
        }
      }]
    ]
  }
}
