{
  "name": "opencode-im-bridge",
  "version": "1.0.0",
  "description": "Universal IM Bridge for OpenCode - bidirectional communication with Telegram, Slack, Discord and more",
  "type": "module",
  "main": "./dist/server.js",
  "exports": {
    ".": "./dist/server.js",
    "./server": "./dist/server.js",
    "./types": "./dist/types/index.js",
    "./adapters/telegram": "./dist/adapters/telegram.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "opencode",
    "plugin",
    "telegram",
    "slack",
    "discord",
    "im",
    "bridge",
    "notifications"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "remark": "^15.0.0",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.0",
    "unist-util-visit": "^5.0.0",
    "mdast-util-to-string": "^4.0.0",
    "mdast-util-gfm": "^3.0.0"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.0.0",
    "@opencode-ai/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.0.0",
    "@opencode-ai/sdk": "^1.0.0",
    "typescript": "^5.0.0",
    "@types/mdast": "^4.0.0"
  }
}
