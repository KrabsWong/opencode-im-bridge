{
  "skill_name": "telegram-image-sender",
  "description": "Test cases for evaluating the telegram-image-sender skill",
  "evals": [
    {
      "id": 1,
      "name": "architecture-diagram-chinese",
      "prompt": "给我看看架构图",
      "expected_output": "Response should include [SEND_IMAGE:architecture] marker",
      "assertions": [
        {
          "name": "contains_image_marker",
          "type": "contains",
          "target": "[SEND_IMAGE:architecture]"
        }
      ]
    },
    {
      "id": 2,
      "name": "architecture-diagram-english",
      "prompt": "show me the architecture diagram",
      "expected_output": "Response should include [SEND_IMAGE:architecture] marker",
      "assertions": [
        {
          "name": "contains_image_marker",
          "type": "contains",
          "target": "[SEND_IMAGE:architecture]"
        }
      ]
    },
    {
      "id": 3,
      "name": "system-design-question",
      "prompt": "系统是怎么设计的？",
      "expected_output": "Response should include architecture explanation and [SEND_IMAGE:architecture] marker",
      "assertions": [
        {
          "name": "contains_image_marker",
          "type": "contains",
          "target": "[SEND_IMAGE:architecture]"
        },
        {
          "name": "contains_explanation",
          "type": "contains_any",
          "target": ["组件", "component", "架构", "architecture", "Telegram", "Bridge", "OpenCode"]
        }
      ]
    },
    {
      "id": 4,
      "name": "workflow-diagram-request",
      "prompt": "给我看流程图",
      "expected_output": "Response should explain workflow and include [SEND_IMAGE:architecture] marker",
      "assertions": [
        {
          "name": "contains_image_marker",
          "type": "contains",
          "target": "[SEND_IMAGE:architecture]"
        }
      ]
    },
    {
      "id": 5,
      "name": "structure-inquiry",
      "prompt": "这个系统的结构是怎样的？",
      "expected_output": "Response should describe system structure and include image marker",
      "assertions": [
        {
          "name": "contains_image_marker",
          "type": "contains",
          "target": "[SEND_IMAGE:architecture]"
        }
      ]
    },
    {
      "id": 6,
      "name": "negative-no-trigger",
      "prompt": "帮我写一段 Python 代码",
      "expected_output": "Response should NOT include any image marker",
      "assertions": [
        {
          "name": "no_image_marker",
          "type": "not_contains",
          "target": "[SEND_IMAGE:"
        }
      ]
    },
    {
      "id": 7,
      "name": "send-to-telegram-request",
      "prompt": "把架构图发给我在 Telegram",
