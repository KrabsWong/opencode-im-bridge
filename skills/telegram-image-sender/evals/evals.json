      "assertions": [
        {
          "name": "contains_image_marker",
          "type": "contains",
          "target": "[SEND_IMAGE:architecture]"
        }
      ]
    },
    {
      "id": 8,
      "name": "diagram-request-english",
      "prompt": "I need to see the system diagram",
      "expected_output": "Response should include [SEND_IMAGE:architecture] marker",
      "assertions": [
        {
          "name": "contains_image_marker",
          "type": "contains",
          "target": "[SEND_IMAGE:architecture]"
        }
      ]
    }
  ]
